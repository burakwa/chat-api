```gitignore
# ======================================================
# Python
# ======================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ======================================================
# Virtual Environment
# ======================================================
.venv/
venv/
env/
ENV/

# ======================================================
# Poetry
# ======================================================
poetry.toml

# ======================================================
# Environment Variables
# ======================================================
.env
.env.*
!.env.example

# ======================================================
# Pytest
# ======================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# ======================================================
# Type Checkers
# ======================================================
.mypy_cache/
.pyre/
.pytype/

# ======================================================
# Linters
# ======================================================
.ruff_cache/

# ======================================================
# IDEs
# ======================================================
.vscode/
.idea/

# ======================================================
# Operating System
# ======================================================
.DS_Store
Thumbs.db

# ======================================================
# Logs
# ======================================================
*.log
logs/

# ======================================================
# Database
# ======================================================
*.db
*.sqlite3

# ======================================================
# Alembic
# ======================================================
alembic/versions/__pycache__/

# ======================================================
# Build
# ======================================================
build/
dist/
*.egg-info/
.eggs/

# ======================================================
# Cache
# ======================================================
.cache/

# ======================================================
# Jupyter
# ======================================================
.ipynb_checkpoints/

# ======================================================
# Misc
# ======================================================
*.swp
*.swo
```
